# API 凭据：用 Anthropic 原生（ANTHROPIC_*）或任意 OpenAI 兼容端点（OPENAI_*）。
# 若 OPENAI_API_KEY 与 OPENAI_BASE_URL 同时设置，则优先走该端点。
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# 选择模型。注意：除 NANOCODE_MODEL 外，其余 NANOCODE_* 变量出于安全考虑一律不从
# .env 加载（见 _DOTENV_BLOCKED_PREFIXES / _DOTENV_ALLOWED_NAMES）。模型也可用
# 命令行 `--model <name>` 覆盖（优先级最高）。
NANOCODE_MODEL=claude-opus-4-6
